# DeepSeek-V4-Pro via EasyClaw OpenAI-compatible proxy
DEEPSEEK_API_KEY=dc-sk-put-yours-here
DEEPSEEK_BASE_URL=https://work-api-srv.easyclaw.cn/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: Perplexity Sonar for on-demand fact-checking (A-1)
# When set, the FactChecker auditor fires a SINGLE websearch per chapter
# when Evaluator has low-confidence hit on landmine_13 (world/era drift).
# Leave blank to disable — FactChecker skips gracefully; Evaluator unaffected.
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://work-api-srv.easyclaw.cn/api/v1/search
PERPLEXITY_MODEL=perplexity/sonar-pro

# Optional: override state dir
# STATE_DIR=state
